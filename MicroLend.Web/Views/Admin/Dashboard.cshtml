@using MicroLend.DAL
@using Microsoft.EntityFrameworkCore
@{
    Layout = "_Layout";
    var usersCount = 0; var borrowersCount = 0; var lendersCount = 0; var loansPending = 0; var loansActive = 0; var investmentsCount = 0;
    List<MicroLend.DAL.Entities.User> recentUsers = new();
    List<MicroLend.DAL.Entities.Loan> pendingLoans = new();
    try
    {
        using var ctx = new MicroLendDbContext();
        usersCount = ctx.Users.Count();
        borrowersCount = ctx.Users.Count(u => u.Role == "Borrower");
        lendersCount = ctx.Users.Count(u => u.Role == "Lender");
        loansPending = ctx.Loans.Count(l => l.Status == "Pending");
        loansActive = ctx.Loans.Count(l => l.Status == "Active" || l.Status == "Approved");
        investmentsCount = ctx.LoanFunders.Count();
        recentUsers = ctx.Users.OrderByDescending(u => u.CreatedAt).Take(5).ToList();
        pendingLoans = ctx.Loans.Where(l => l.Status == "Pending").OrderByDescending(l => l.CreatedAt).Take(8).ToList();
    }
    catch { }
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h1 style="color:#008577">Admin Dashboard</h1>
            <p class="text-muted">Full system access, user management, monitoring and configuration.</p>
        </div>
        <div>
            <a class="btn btn-outline-secondary me-2" href="/">Home</a>
            <a class="btn btn-success" style="background-color:#008577;border-color:#008577;color:#fff" href="/Admin/PendingLoans">Manage Pending</a>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-md-3">
            <div class="card p-3">
                <h6>Users</h6>
                <p class="display-6">@usersCount</p>
                <p class="mb-0 text-muted">Borrowers: @borrowersCount | Lenders: @lendersCount</p>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card p-3">
                <h6>Loans</h6>
                <p class="display-6">@loansActive</p>
                <p class="mb-0 text-muted">Pending: @loansPending</p>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card p-3">
                <h6>Investments</h6>
                <p class="display-6">@investmentsCount</p>
                <p class="mb-0 text-muted">Monitor funding and returns</p>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card p-3">
                <h6>System</h6>
                <p class="mb-0 text-muted">Logs & Configuration</p>
                <a class="btn btn-sm btn-outline-secondary mt-2" href="#">View Logs</a>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-md-6">
            <div class="card p-3">
                <h5>User Management</h5>
                <p class="text-muted">Manage account types and access.</p>
                <table class="table table-sm">
                    <thead><tr><th>Id</th><th>Username</th><th>Role</th><th></th></tr></thead>
                    <tbody>
                    @foreach(var u in recentUsers) {
                        <tr>
                            <td>@u.Id</td>
                            <td>@u.Username</td>
                            <td>@u.Role</td>
                            <td><a class="btn btn-sm btn-outline-primary" href="/Admin/Users/Edit/@u.Id">Edit</a></td>
                        </tr>
                    }
                    </tbody>
                </table>
                <a class="btn btn-sm btn-outline-success" href="/Admin/Users">Manage all users</a>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card p-3">
                <h5>Pending Loans</h5>
                <p class="text-muted">Approve or reject loan requests.</p>
                @if (pendingLoans.Count == 0)
                {
                    <div class="alert alert-info">No pending loans</div>
                }
                else
                {
                    <table class="table table-sm">
                        <thead><tr><th>Id</th><th>Purpose</th><th>Amount</th><th>Borrower</th><th></th></tr></thead>
                        <tbody>
                        @foreach(var l in pendingLoans) {
                            <tr>
                                <td>@l.Id</td>
                                <td>@l.Purpose</td>
                                <td>@l.Amount</td>
                                <td>@l.BorrowerId</td>
                                <td><a class="btn btn-sm btn-success" href="/Admin/PendingLoans">Review</a></td>
                            </tr>
                        }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-12">
            <div class="card p-3">
                <h5>System Configuration</h5>
                <p class="text-muted">Adjust settings, parameters and view audit trails.</p>
                <a class="btn btn-outline-secondary btn-sm" href="/Admin/Settings">Open Configuration</a>
            </div>
        </div>
    </div>

</div>

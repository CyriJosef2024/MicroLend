@{
    Layout = "_Layout";
}
<div class="container py-4">
    <h2 style="color:#008577">Users</h2>
    <p>List of users. Use Edit to change role or reset password; Deactivate to disable account.</p>
    <table class="table">
        <thead>
            <tr><th>Id</th><th>Username</th><th>Role</th><th>Actions</th></tr>
        </thead>
        <tbody>
        @if (Model != null) {
            foreach(var u in (System.Collections.IEnumerable)Model) {
                dynamic du = u;
                <tr>
                    <td>@du.Id</td>
                    <td>@du.Username</td>
                    <td>@du.Role</td>
                    <td>
                        <a class="btn btn-sm btn-primary" href="/Admin/EditUser/@du.Id">Edit</a>
                        <form method="post" asp-action="DeactivateUser" class="d-inline ms-2" style="display:inline;">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@du.Id" />
                            <button class="btn btn-sm btn-warning">Deactivate</button>
                        </form>
                    </td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>
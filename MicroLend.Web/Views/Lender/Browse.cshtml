@model List<MicroLend.DAL.Entities.Loan>
@{
    Layout = "_Layout";
}
<div class="container py-4">
    <h2 style="color:#008577">Browse Loans</h2>
    <form method="get" class="row g-2 mb-3">
        <div class="col-auto">
            <input name="minAmount" class="form-control" placeholder="Min amount" />
        </div>
        <div class="col-auto">
            <input name="maxAmount" class="form-control" placeholder="Max amount" />
        </div>
        <div class="col-auto">
            <select name="risk" class="form-control">
                <option value="">Any risk</option>
                <option>Low</option>
                <option>Medium</option>
                <option>High</option>
            </select>
        </div>
        <div class="col-auto">
            <button class="btn btn-outline-success">Filter</button>
        </div>
    </form>

    <table class="table">
        <thead><tr><th>Id</th><th>Purpose</th><th>Amount</th><th>Funded</th><th>Risk</th><th></th></tr></thead>
        <tbody>
        @foreach(var l in Model) {
            <tr>
                <td>@l.Id</td>
                <td>@l.Purpose</td>
                <td>@l.Amount</td>
                <td>@l.CurrentAmount</td>
                <td>@l.RiskScore</td>
                <td>
                    <div class="d-flex">
                        <form method="post" asp-action="Invest" class="me-2">
                            <input type="hidden" name="loanId" value="@l.Id" />
                            <div class="input-group">
                                <input name="amount" class="form-control" placeholder="Amount" />
                                <button class="btn btn-success" style="background-color:#008577;border-color:#008577">Invest</button>
                            </div>
                        </form>
                        <a class="btn btn-outline-secondary" href="/Lender/Details/@l.Id">Details</a>
                    </div>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>
@{
    Layout = "_Layout";
}
<div class="hero">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-md-7">
                <h1>MicroLend — Community Micro‑Loans</h1>
                <p class="lead">MicroLend digitizes community micro-lending: onboarding, gamified credit scoring, crowdfunding and repayment tracking.</p>
                <p>
                    <a class="btn btn-cta btn-lg me-2" href="/Account/Register">Apply / Sign up</a>
                    <a class="btn btn-outline-primary btn-lg" href="/Account/Login">Login</a>
                </p>
            </div>
            <div class="col-md-5 text-center">
                <img src="https://via.placeholder.com/420x260.png?text=MicroLend" class="img-fluid" />
            </div>
        </div>
    </div>
</div>

<div class="container py-4">
    <div class="row">
        <div class="col-md-4">
            <h4>Credit Quiz</h4>
            <p>A gamified quiz evaluates borrower risk and assigns an initial credit score (0–100).</p>
            <a class="btn btn-outline-primary" href="/Borrower/Apply">Learn more</a>
        </div>
        <div class="col-md-4">
            <h4>Crowdfunding</h4>
            <p>Multiple lenders fund a loan and receive proportional dividends.</p>
            <a class="btn btn-outline-primary" href="/Lender/Browse">Browse loans</a>
        </div>
        <div class="col-md-4">
            <h4>Emergency Pool</h4>
            <p>Lenders can donate interest to an emergency pool to help borrowers in crisis.</p>
        </div>
    </div>
</div>

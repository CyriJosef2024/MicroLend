@{
    Layout = "_Layout";
}
<div class="container py-4">
    <h2>Borrower Dashboard</h2>
    <p>Welcome. Use the menu to apply, upload documents, view loans, or make repayments.</p>
    <div class="row">
        <div class="col-md-4">
            <a class="btn btn-primary w-100 mb-2" href="/Borrower/Apply">Apply for Loan</a>
        </div>
        <div class="col-md-4">
            <a class="btn btn-secondary w-100 mb-2" href="/Borrower/MyLoans">My Loans</a>
        </div>
        <div class="col-md-4">
            <a class="btn btn-success w-100 mb-2" href="/Borrower/Repay">Make Repayment</a>
        </div>
    </div>
    <div class="card mt-4 p-3">
        <h5>Upload Documents</h5>
        @await Html.PartialAsync("_UploadPartial")
    </div>
    <div class="row mt-4">
        <div class="col-md-6">
            <div class="card p-3">
                <h5>Credit Score</h5>
                <p class="display-6">@ViewBag.CreditScore</p>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card p-3">
                <h5>Active Loans</h5>
                <p class="display-6">@ViewBag.ActiveLoans</p>
            </div>
        </div>
    </div>
</div>
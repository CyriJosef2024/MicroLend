@using System.Security.Claims
<nav class="navbar navbar-expand-lg" style="background-color:#0264AA;">
    <div class="container-fluid">
        <a class="navbar-brand text-white" href="/">MicroLend</a>
        <div class="collapse navbar-collapse">
            <ul class="navbar-nav ms-auto">
                if(User?.Identity?.IsAuthenticated == true)
                {
                    var role = User.Claims.FirstOrDefault(c => c.Type == ClaimTypes.Role)?.Value ?? "";
                    if (role == "Borrower") { <text><li class="nav-item"><a class="nav-link text-white" href="/Borrower/Dashboard">Borrower</a></li></text>; }
                    if (role == "Lender") { <text><li class="nav-item"><a class="nav-link text-white" href="/Lender/Dashboard">Lender</a></li></text>; }
                    if (role == "Admin") { <text><li class="nav-item"><a class="nav-link text-white" href="/Admin/Dashboard">Admin</a></li></text>; }
                    <li class="nav-item"><a class="nav-link text-white" href="/Account/Logout">Logout</a></li>
                }
                else
                {
                    <li class="nav-item"><a class="nav-link text-white" href="/Account/Login">Login</a></li>
                    <li class="nav-item"><a class="nav-link text-white" href="/Account/Register">Sign up</a></li>
                }
            </ul>
        </div>
    </div>
</nav>
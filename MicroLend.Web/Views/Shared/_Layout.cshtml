<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>MicroLend</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        /* Simple brand palette */
        :root { --brand-blue: #0b6fa4; --brand-green: #2eab4f; }
        .site-header { background: var(--brand-blue); color: #fff; }
        .site-header .navbar-brand { color: #fff; font-weight:600; }
        .btn-cta { background: var(--brand-green); color: #fff; }
        .hero { background:#f8fafc; padding: 40px 0; }
        main { padding: 24px 0; }
    </style>
</head>
<body>
    <header class="site-header">
        <nav class="container navbar navbar-expand-lg">
            <a class="navbar-brand" href="/">MicroLend</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link text-white" href="/">Home</a></li>
                    <li class="nav-item"><a class="nav-link text-white" href="/Borrower/Dashboard">Borrower</a></li>
                    <li class="nav-item"><a class="nav-link text-white" href="/Lender/Dashboard">Lender</a></li>
                    <li class="nav-item"><a class="nav-link text-white" href="/Admin/Dashboard">Admin</a></li>
                    <li class="nav-item"><a class="nav-link text-white" href="/Account/Login">Login</a></li>
                    <li class="nav-item ms-2"><a class="btn btn-cta" href="/Account/Register">Sign up</a></li>
                </ul>
            </div>
        </nav>
    </header>
    @await Html.PartialAsync("_Flash")
    <main role="main" class="container">@RenderBody()</main>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>